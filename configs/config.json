{
  "ScanPaths": [
    "/etc/ssl/certs",
    "/usr/local/share/ca-certificates"
  ],
  "ScanPathsWindows": [
    "C:\\ProgramData\\ssl\\certs",
    "C:\\Windows\\System32\\certificates"
  ],
  "ScanIntervalSeconds": 60,
  "HeartbeatIntervalSeconds": 30,
  "ExpiringThresholdDays": 10,
  "LogPath": "../../logs/",
  "Verbose": true,
  "LogLevel": "DEBUG",
  "AWSEndpoint": "https://your-api-id.execute-api.us-east-1.amazonaws.com/ingest",
  "TLSVerify": true,
  "MaxRetries": 3,
  "AgentName": "CertHoundAgent",
  "IncludeIPAddresses": false,
  "IncludeSelfSigned": false,
  "PayloadVersion": "1.0",
  "OrgID": ""
}
